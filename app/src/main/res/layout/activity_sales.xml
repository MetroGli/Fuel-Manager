<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#0D1117">

    <!-- HEADER -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="20dp"
        android:background="@drawable/bg_header_gradient">

        <ImageButton
            android:id="@+id/btnBack"
            android:layout_width="38dp"
            android:layout_height="38dp"
            android:src="@drawable/ic_arrow_back"
            android:background="@drawable/bg_icon_btn"
            android:tint="#FFFFFF"
            android:contentDescription="Volver"/>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_weight="1"
            android:layout_marginStart="14dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Registrar Venta"
                android:textSize="20sp"
                android:textColor="#FFFFFF"
                android:textStyle="bold"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Descuenta del inventario automáticamente"
                android:textSize="12sp"
                android:textColor="#B0BEC5"/>
        </LinearLayout>

        <ImageView
            android:layout_width="30dp"
            android:layout_height="30dp"
            android:src="@drawable/ic_sale"
            android:tint="#66BB6A"/>
    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="20dp">

            <!-- FORMULARIO -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Nueva venta"
                android:textSize="13sp"
                android:textColor="#B0BEC5"
                android:textAllCaps="true"
                android:letterSpacing="0.08"
                android:layout_marginStart="20dp"
                android:layout_marginTop="20dp"
                android:layout_marginBottom="10dp"/>

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:layout_marginEnd="16dp"
                app:cardBackgroundColor="#161B22"
                app:cardCornerRadius="20dp"
                app:cardElevation="4dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <!-- usuario -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Usuario"
                        android:textSize="12sp"
                        android:textColor="#B0BEC5"
                        android:layout_marginBottom="6dp"/>

                    <androidx.cardview.widget.CardView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="14dp"
                        app:cardBackgroundColor="#1E2A3A"
                        app:cardCornerRadius="12dp"
                        app:cardElevation="0dp">
                        <Spinner
                            android:id="@+id/spinnerClient"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginBottom="8dp" />
                    </androidx.cardview.widget.CardView>

                    <!-- Tipo combustible -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Combustible"
                        android:textSize="12sp"
                        android:textColor="#B0BEC5"
                        android:layout_marginBottom="6dp"/>


                    <androidx.cardview.widget.CardView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="14dp"
                        app:cardBackgroundColor="#1E2A3A"
                        app:cardCornerRadius="12dp"
                        app:cardElevation="0dp">
                        <Spinner
                            android:id="@+id/spinnerFuelSale"
                            android:layout_width="match_parent"
                            android:layout_height="48dp"
                            android:paddingStart="12dp"
                            android:popupBackground="#161B22"/>
                    </androidx.cardview.widget.CardView>

                    <!-- Stock disponible -->
                    <TextView
                        android:id="@+id/tvStockInfo"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Stock disponible: --"
                        android:textSize="12sp"
                        android:textColor="#66BB6A"
                        android:layout_marginBottom="14dp"
                        android:paddingStart="4dp"/>

                    <!-- Volumen -->
                    <com.google.android.material.textfield.TextInputLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="Volumen a vender (galones)"
                        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                        app:boxBackgroundColor="#1E2A3A"
                        app:boxStrokeColor="#2C3E50"
                        app:hintTextColor="#B0BEC5"
                        android:layout_marginBottom="12dp">
                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/etSaleVolume"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:inputType="numberDecimal"
                            android:textColor="#FFFFFF"/>
                    </com.google.android.material.textfield.TextInputLayout>

                    <!-- Precio por galón -->
                    <com.google.android.material.textfield.TextInputLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="Precio por galón (COP)"
                        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                        app:boxBackgroundColor="#1E2A3A"
                        app:boxStrokeColor="#2C3E50"
                        app:hintTextColor="#B0BEC5"
                        android:layout_marginBottom="12dp">
                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/etSalePrice"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:inputType="numberDecimal"
                            android:textColor="#FFFFFF"/>
                    </com.google.android.material.textfield.TextInputLayout>

                    <!-- Placa -->
                    <com.google.android.material.textfield.TextInputLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="Placa del vehículo (opcional)"
                        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                        app:boxBackgroundColor="#1E2A3A"
                        app:boxStrokeColor="#2C3E50"
                        app:hintTextColor="#B0BEC5"
                        android:layout_marginBottom="12dp">
                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/etSalePlate"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:inputType="textCapCharacters"
                            android:textColor="#FFFFFF"/>
                    </com.google.android.material.textfield.TextInputLayout>

                    <!-- Total calculado -->
                    <TextView
                        android:id="@+id/tvSaleTotal"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Total: $0"
                        android:textSize="18sp"
                        android:textColor="#66BB6A"
                        android:textStyle="bold"
                        android:gravity="end"
                        android:layout_marginBottom="16dp"/>

                    <!-- Botón registrar -->
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnRegistrarVenta"
                        android:layout_width="match_parent"
                        android:layout_height="52dp"
                        android:text="Registrar venta"
                        android:textAllCaps="false"
                        android:textSize="15sp"
                        app:cornerRadius="12dp"
                        app:backgroundTint="#2E7D32"/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- HISTORIAL -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Historial de ventas"
                android:textSize="13sp"
                android:textColor="#B0BEC5"
                android:textAllCaps="true"
                android:letterSpacing="0.08"
                android:layout_marginStart="20dp"
                android:layout_marginTop="24dp"
                android:layout_marginBottom="10dp"/>

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/recyclerSales"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:nestedScrollingEnabled="false"/>

        </LinearLayout>
    </ScrollView>
</LinearLayout>