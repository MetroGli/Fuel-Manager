<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#0D1117">

    <!-- HEADER -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="20dp"
        android:background="@drawable/bg_header_gradient">

        <ImageButton
            android:id="@+id/btnBack"
            android:layout_width="38dp"
            android:layout_height="38dp"
            android:src="@drawable/ic_arrow_back"
            android:background="@drawable/bg_icon_btn"
            android:tint="#FFFFFF"
            android:contentDescription="Volver"/>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_weight="1"
            android:layout_marginStart="14dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Precios en Bogotá"
                android:textSize="20sp"
                android:textColor="#FFFFFF"
                android:textStyle="bold"/>

            <TextView
                android:id="@+id/tvStationCount"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="10 estaciones"
                android:textSize="12sp"
                android:textColor="#B0BEC5"/>
        </LinearLayout>

        <!-- Botón campana alertas -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnAlerts"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:text="🔔 Alertas"
            android:textSize="12sp"
            android:textColor="#E65100"
            app:strokeColor="#E65100"
            app:cornerRadius="20dp"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"/>
    </LinearLayout>

    <!-- FILTRO ZONA -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingTop="14dp"
        android:paddingBottom="8dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Zona:"
            android:textSize="13sp"
            android:textColor="#B0BEC5"
            android:layout_marginEnd="10dp"/>

        <androidx.cardview.widget.CardView
            android:layout_width="0dp"
            android:layout_height="42dp"
            android:layout_weight="1"
            app:cardBackgroundColor="#1E2A3A"
            app:cardCornerRadius="10dp"
            app:cardElevation="0dp">
            <Spinner
                android:id="@+id/spinnerZone"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:paddingStart="12dp"
                android:popupBackground="#161B22"/>
        </androidx.cardview.widget.CardView>
    </LinearLayout>

    <!-- Hint toque -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="💡 Toca una estación para activar una alerta de precio"
        android:textSize="11sp"
        android:textColor="#546E7A"
        android:gravity="center"
        android:paddingBottom="8dp"/>

    <!-- LISTA -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerStations"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:paddingBottom="12dp"
        android:clipToPadding="false"/>

</LinearLayout>