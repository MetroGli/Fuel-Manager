<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent" android:layout_height="wrap_content"
    android:layout_marginStart="16dp" android:layout_marginEnd="16dp"
    android:layout_marginTop="5dp" android:layout_marginBottom="5dp"
    app:cardBackgroundColor="#161B22" app:cardCornerRadius="14dp" app:cardElevation="2dp">
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="horizontal" android:padding="16dp" android:gravity="center_vertical">
        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
            android:orientation="vertical" android:layout_weight="1">
            <TextView android:id="@+id/tvReceiptIdPdf" android:layout_width="wrap_content"
                android:layout_height="wrap_content" android:textSize="13sp"
                android:textColor="#FFFFFF" android:textStyle="bold"/>
            <TextView android:id="@+id/tvReceiptFuelPdf" android:layout_width="wrap_content"
                android:layout_height="wrap_content" android:textSize="12sp"
                android:textColor="#E65100" android:layout_marginTop="2dp"/>
            <TextView android:id="@+id/tvReceiptDetailsPdf" android:layout_width="wrap_content"
                android:layout_height="wrap_content" android:textSize="11sp"
                android:textColor="#B0BEC5" android:layout_marginTop="2dp"/>
            <TextView android:id="@+id/tvReceiptPlatePdf" android:layout_width="wrap_content"
                android:layout_height="wrap_content" android:textSize="11sp"
                android:textColor="#78909C" android:layout_marginTop="2dp" android:visibility="gone"/>
            <TextView android:id="@+id/tvReceiptDatePdf" android:layout_width="wrap_content"
                android:layout_height="wrap_content" android:textSize="10sp"
                android:textColor="#546E7A" android:layout_marginTop="2dp"/>
        </LinearLayout>
        <com.google.android.material.button.MaterialButton android:id="@+id/btnGeneratePdf"
            android:layout_width="wrap_content" android:layout_height="36dp"
            android:text="PDF" android:textSize="12sp" android:textAllCaps="false"
            app:cornerRadius="8dp" app:backgroundTint="#66BB6A"
            android:layout_marginStart="8dp"/>
    </LinearLayout>
</androidx.cardview.widget.CardView>