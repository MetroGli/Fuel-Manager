<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0D1117"
    android:orientation="vertical">

    <!-- ── HEADER ── -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_header_gradient"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:padding="20dp">

        <ImageButton
            android:id="@+id/btnBack"
            android:layout_width="38dp"
            android:layout_height="38dp"
            android:background="@drawable/bg_icon_btn"
            android:contentDescription="Volver"
            android:src="@drawable/ic_arrow_back"
            android:tint="#FFFFFF" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="14dp"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Inventario"
                android:textColor="#FFFFFF"
                android:textSize="20sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Entradas y salidas de combustible"
                android:textColor="#B0BEC5"
                android:textSize="12sp" />
        </LinearLayout>

        <ImageView
            android:layout_width="30dp"
            android:layout_height="30dp"
            android:src="@drawable/ic_inventory"
            android:tint="#FF8F00" />
    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="false">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="20dp">

            <!-- ── STOCK ACTUAL ── -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="20dp"
                android:layout_marginTop="20dp"
                android:layout_marginBottom="10dp"
                android:letterSpacing="0.08"
                android:text="Stock actual"
                android:textAllCaps="true"
                android:textColor="#B0BEC5"
                android:textSize="13sp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingStart="16dp"
                android:paddingEnd="16dp">

                <!-- Corriente -->
                <androidx.cardview.widget.CardView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_margin="4dp"
                    android:layout_weight="1"
                    app:cardBackgroundColor="#161B22"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="3dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center"
                        android:orientation="vertical"
                        android:padding="14dp">

                        <View
                            android:layout_width="8dp"
                            android:layout_height="8dp"
                            android:layout_marginBottom="6dp"
                            android:background="@drawable/badge_best_price" />

                        <TextView
                            android:id="@+id/tvStockCorriente"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0.0 gal"
                            android:textColor="#E65100"
                            android:textSize="18sp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:text="Corriente"
                            android:textColor="#78909C"
                            android:textSize="11sp" />

                        <TextView
                            android:id="@+id/tvAlertCorriente"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:text="⚠ Stock bajo"
                            android:textColor="#EF5350"
                            android:textSize="10sp"
                            android:visibility="gone" />
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <!-- Extra -->
                <androidx.cardview.widget.CardView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_margin="4dp"
                    android:layout_weight="1"
                    app:cardBackgroundColor="#161B22"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="3dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center"
                        android:orientation="vertical"
                        android:padding="14dp">

                        <View
                            android:layout_width="8dp"
                            android:layout_height="8dp"
                            android:layout_marginBottom="6dp"
                            android:background="@drawable/badge_coming_soon_yellow" />

                        <TextView
                            android:id="@+id/tvStockExtra"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0.0 gal"
                            android:textColor="#FF8F00"
                            android:textSize="18sp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:text="Extra"
                            android:textColor="#78909C"
                            android:textSize="11sp" />

                        <TextView
                            android:id="@+id/tvAlertExtra"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:text="⚠ Stock bajo"
                            android:textColor="#EF5350"
                            android:textSize="10sp"
                            android:visibility="gone" />
                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <!-- ACPM -->
                <androidx.cardview.widget.CardView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_margin="4dp"
                    android:layout_weight="1"
                    app:cardBackgroundColor="#161B22"
                    app:cardCornerRadius="16dp"
                    app:cardElevation="3dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center"
                        android:orientation="vertical"
                        android:padding="14dp">

                        <View
                            android:layout_width="8dp"
                            android:layout_height="8dp"
                            android:layout_marginBottom="6dp"
                            android:background="@drawable/badge_coming_soon_blue" />

                        <TextView
                            android:id="@+id/tvStockAcpm"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0.0 gal"
                            android:textColor="#42A5F5"
                            android:textSize="18sp"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="2dp"
                            android:text="ACPM"
                            android:textColor="#78909C"
                            android:textSize="11sp" />

                        <TextView
                            android:id="@+id/tvAlertAcpm"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:text="⚠ Stock bajo"
                            android:textColor="#EF5350"
                            android:textSize="10sp"
                            android:visibility="gone" />
                    </LinearLayout>
                </androidx.cardview.widget.CardView>
            </LinearLayout>

            <!-- ── FORMULARIO ── -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="20dp"
                android:layout_marginTop="24dp"
                android:layout_marginBottom="10dp"
                android:letterSpacing="0.08"
                android:text="Registrar movimiento"
                android:textAllCaps="true"
                android:textColor="#B0BEC5"
                android:textSize="13sp" />

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:layout_marginEnd="16dp"
                app:cardBackgroundColor="#161B22"
                app:cardCornerRadius="20dp"
                app:cardElevation="4dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <!-- Toggle ENTRADA / SALIDA -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="52dp"
                        android:layout_marginBottom="16dp"
                        android:background="@drawable/bg_icon_btn"
                        android:orientation="horizontal"
                        android:padding="4dp">

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnTypeEntrada"
                            android:layout_width="0dp"
                            android:layout_height="match_parent"
                            android:layout_weight="1"
                            android:text="▲ Entrada"
                            android:textAllCaps="false"
                            android:textColor="#FFFFFF"
                            android:textSize="14sp"
                            app:backgroundTint="#2E7D32"
                            app:cornerRadius="10dp" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/btnTypeSalida"
                            android:layout_width="0dp"
                            android:layout_height="match_parent"
                            android:layout_weight="1"
                            android:text="▼ Salida"
                            android:textAllCaps="false"
                            android:textColor="#78909C"
                            android:textSize="14sp"
                            app:backgroundTint="#1E2A3A"
                            app:cornerRadius="10dp" />
                    </LinearLayout>

                    <!-- Spinner tipo combustible -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="6dp"
                        android:text="Combustible"
                        android:textColor="#B0BEC5"
                        android:textSize="12sp" />

                    <androidx.cardview.widget.CardView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="14dp"
                        app:cardBackgroundColor="#1E2A3A"
                        app:cardCornerRadius="12dp"
                        app:cardElevation="0dp">

                        <Spinner
                            android:id="@+id/spinnerFuel"
                            android:layout_width="match_parent"
                            android:layout_height="48dp"
                            android:paddingStart="12dp"
                            android:popupBackground="#161B22" />
                        <!-- spinnerMovType oculto, manejado por toggle -->
                        <Spinner
                            android:id="@+id/spinnerMovType"
                            android:layout_width="0dp"
                            android:layout_height="0dp"
                            android:visibility="gone" />
                    </androidx.cardview.widget.CardView>

                    <!-- Volumen -->
                    <com.google.android.material.textfield.TextInputLayout
                        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="12dp"
                        android:hint="Volumen (galones)"
                        app:boxBackgroundColor="#1E2A3A"
                        app:boxStrokeColor="#2C3E50"
                        app:hintTextColor="#B0BEC5">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/etVolume"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:inputType="numberDecimal"
                            android:textColor="#FFFFFF" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <!-- Nota -->
                    <com.google.android.material.textfield.TextInputLayout
                        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="16dp"
                        android:hint="Observación (opcional)"
                        app:boxBackgroundColor="#1E2A3A"
                        app:boxStrokeColor="#2C3E50"
                        app:hintTextColor="#B0BEC5">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/etNote"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:maxLines="2"
                            android:textColor="#FFFFFF" />
                    </com.google.android.material.textfield.TextInputLayout>

                    <!-- Botón registrar -->
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnRegistrar"
                        android:layout_width="match_parent"
                        android:layout_height="52dp"
                        android:text="Registrar movimiento"
                        android:textAllCaps="false"
                        android:textSize="15sp"
                        app:backgroundTint="#E65100"
                        app:cornerRadius="12dp" />
                    <Button
                        android:id="@+id/btnIrAPrecios"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Precios normativos"
                        android:layout_marginTop="8dp"/>
                </LinearLayout>

            </androidx.cardview.widget.CardView>

            <!-- ── HISTORIAL ── -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="20dp"
                android:layout_marginTop="24dp"
                android:layout_marginBottom="10dp"
                android:letterSpacing="0.08"
                android:text="Historial de movimientos"
                android:textAllCaps="true"
                android:textColor="#B0BEC5"
                android:textSize="13sp" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/recyclerMovements"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:nestedScrollingEnabled="false" />

        </LinearLayout>
    </ScrollView>
</LinearLayout>