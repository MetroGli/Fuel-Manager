<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#0D1117">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_header_gradient"
        android:orientation="vertical"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:paddingTop="48dp"
        android:paddingBottom="20dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="8dp">

            <ImageButton
                android:id="@+id/btnBack"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:background="@drawable/bg_icon_btn"
                android:src="@drawable/ic_arrow_back"
                android:tint="#E65100"
                android:contentDescription="Volver"
                android:layout_marginEnd="12dp"/>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="ACTUALIZAR PRECIOS"
                    android:textColor="#E65100"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.1"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Modificar precios de estaciones"
                    android:textColor="#B0BEC5"
                    android:textSize="12sp"/>
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:padding="16dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Card: Seleccionar estación -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardBackgroundColor="#161B22"
                app:cardCornerRadius="12dp"
                app:cardElevation="4dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="ESTACIÓN DE DESTINO"
                        android:textColor="#E65100"
                        android:textSize="10sp"
                        android:textStyle="bold"
                        android:letterSpacing="0.1"
                        android:layout_marginBottom="10dp"/>

                    <Spinner
                        android:id="@+id/spinnerStation"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:background="#1E2632"
                        android:paddingStart="12dp"
                        android:paddingEnd="12dp"/>

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Card: Nuevos precios -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp"
                app:cardBackgroundColor="#161B22"
                app:cardCornerRadius="12dp"
                app:cardElevation="4dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="NUEVOS PRECIOS ($/GALÓN)"
                        android:textColor="#E65100"
                        android:textSize="10sp"
                        android:textStyle="bold"
                        android:letterSpacing="0.1"
                        android:layout_marginBottom="14dp"/>

                    <!-- Corriente -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="🟠 Corriente"
                        android:textColor="#B0BEC5"
                        android:textSize="12sp"
                        android:layout_marginBottom="4dp"/>

                    <TextView
                        android:id="@+id/tvCurrentCorriente"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Actual: cargando..."
                        android:textColor="#546E7A"
                        android:textSize="10sp"
                        android:layout_marginBottom="4dp"/>

                    <EditText
                        android:id="@+id/etCorriente"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:background="#1E2632"
                        android:textColor="#FFFFFF"
                        android:textColorHint="#546E7A"
                        android:hint="Precio corriente"
                        android:inputType="numberDecimal"
                        android:paddingStart="12dp"
                        android:paddingEnd="12dp"
                        android:layout_marginBottom="14dp"/>

                    <!-- Extra -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="🟡 Extra"
                        android:textColor="#B0BEC5"
                        android:textSize="12sp"
                        android:layout_marginBottom="4dp"/>

                    <TextView
                        android:id="@+id/tvCurrentExtra"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Actual: cargando..."
                        android:textColor="#546E7A"
                        android:textSize="10sp"
                        android:layout_marginBottom="4dp"/>

                    <EditText
                        android:id="@+id/etExtra"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:background="#1E2632"
                        android:textColor="#FFFFFF"
                        android:textColorHint="#546E7A"
                        android:hint="Precio extra"
                        android:inputType="numberDecimal"
                        android:paddingStart="12dp"
                        android:paddingEnd="12dp"
                        android:layout_marginBottom="14dp"/>

                    <!-- ACPM -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="🔵 ACPM"
                        android:textColor="#B0BEC5"
                        android:textSize="12sp"
                        android:layout_marginBottom="4dp"/>

                    <TextView
                        android:id="@+id/tvCurrentAcpm"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Actual: cargando..."
                        android:textColor="#546E7A"
                        android:textSize="10sp"
                        android:layout_marginBottom="4dp"/>

                    <EditText
                        android:id="@+id/etAcpm"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:background="#1E2632"
                        android:textColor="#FFFFFF"
                        android:textColorHint="#546E7A"
                        android:hint="Precio ACPM"
                        android:inputType="numberDecimal"
                        android:paddingStart="12dp"
                        android:paddingEnd="12dp"
                        android:layout_marginBottom="4dp"/>

                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Botón confirmar -->
            <Button
                android:id="@+id/btnUpdate"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:text="ACTUALIZAR PRECIOS"
                android:textColor="#FFFFFF"
                android:textStyle="bold"
                android:backgroundTint="#E65100"
                android:layout_marginBottom="16dp"/>

            <!-- Historial -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="HISTORIAL DE ACTUALIZACIONES"
                android:textColor="#E65100"
                android:textSize="10sp"
                android:textStyle="bold"
                android:letterSpacing="0.1"
                android:layout_marginBottom="8dp"/>

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/recyclerHistory"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:nestedScrollingEnabled="false"/>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</LinearLayout>