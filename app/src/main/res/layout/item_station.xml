<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginStart="16dp"
    android:layout_marginEnd="16dp"
    android:layout_marginTop="6dp"
    android:layout_marginBottom="6dp"
    app:cardBackgroundColor="#161B22"
    app:cardCornerRadius="16dp"
    app:cardElevation="3dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="16dp"
        android:gravity="center_vertical">

        <!-- Número ranking -->
        <TextView
            android:id="@+id/tvRank"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:gravity="center"
            android:textSize="13sp"
            android:textStyle="bold"
            android:textColor="#B0BEC5"
            android:background="@drawable/badge_rank"/>

        <!-- Info estación -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_weight="1"
            android:layout_marginStart="12dp">

            <TextView
                android:id="@+id/tvStationName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Nombre estación"
                android:textSize="14sp"
                android:textColor="#FFFFFF"
                android:textStyle="bold"/>

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginTop="3dp">

                <ImageView
                    android:layout_width="10dp"
                    android:layout_height="10dp"
                    android:src="@drawable/ic_price_zone"
                    android:tint="#78909C"/>

                <TextView
                    android:id="@+id/tvZone"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Zona"
                    android:textSize="11sp"
                    android:textColor="#78909C"
                    android:layout_marginStart="4dp"/>
            </LinearLayout>

            <TextView
                android:id="@+id/tvAddress"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Dirección"
                android:textSize="11sp"
                android:textColor="#546E7A"
                android:layout_marginTop="2dp"
                android:maxLines="1"
                android:ellipsize="end"/>
        </LinearLayout>

        <!-- Precios -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="end">

            <!-- Corriente -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="C "
                    android:textSize="10sp"
                    android:textColor="#78909C"/>
                <TextView
                    android:id="@+id/tvPriceCorriente"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="$9.400"
                    android:textSize="14sp"
                    android:textColor="#E65100"
                    android:textStyle="bold"/>
            </LinearLayout>

            <!-- Extra -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginTop="3dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="E "
                    android:textSize="10sp"
                    android:textColor="#78909C"/>
                <TextView
                    android:id="@+id/tvPriceExtra"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="$10.200"
                    android:textSize="13sp"
                    android:textColor="#FF8F00"/>
            </LinearLayout>

            <!-- ACPM -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginTop="3dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="D "
                    android:textSize="10sp"
                    android:textColor="#78909C"/>
                <TextView
                    android:id="@+id/tvPriceAcpm"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="$8.900"
                    android:textSize="13sp"
                    android:textColor="#42A5F5"/>
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>
</androidx.cardview.widget.CardView>