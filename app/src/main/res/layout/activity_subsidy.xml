<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent" android:layout_height="match_parent"
    android:orientation="vertical" android:background="#0D1117">
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="horizontal" android:gravity="center_vertical"
        android:padding="20dp" android:background="@drawable/bg_header_gradient">
        <ImageButton android:id="@+id/btnBack" android:layout_width="38dp" android:layout_height="38dp"
            android:src="@drawable/ic_arrow_back" android:background="@drawable/bg_icon_btn"
            android:tint="#FFFFFF" android:contentDescription="Volver"/>
        <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
            android:orientation="vertical" android:layout_weight="1" android:layout_marginStart="14dp">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Gestion de subsidios" android:textSize="20sp"
                android:textColor="#FFFFFF" android:textStyle="bold"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Asignar descuentos por region o usuario"
                android:textSize="12sp" android:textColor="#B0BEC5"/>
        </LinearLayout>
    </LinearLayout>
    <ScrollView android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="1">
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="vertical" android:paddingBottom="20dp">
            <androidx.cardview.widget.CardView android:layout_width="match_parent"
                android:layout_height="wrap_content" android:layout_margin="16dp"
                app:cardBackgroundColor="#161B22" app:cardCornerRadius="20dp">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="vertical" android:padding="20dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Tipo de destinatario" android:textSize="12sp"
                        android:textColor="#B0BEC5" android:layout_marginBottom="6dp"/>
                    <androidx.cardview.widget.CardView android:layout_width="match_parent"
                        android:layout_height="wrap_content" android:layout_marginBottom="14dp"
                        app:cardBackgroundColor="#1E2A3A" app:cardCornerRadius="12dp" app:cardElevation="0dp">
                        <Spinner android:id="@+id/spinnerTargetType" android:layout_width="match_parent"
                            android:layout_height="48dp" android:paddingStart="12dp" android:popupBackground="#161B22"/>
                    </androidx.cardview.widget.CardView>
                    <TextView android:id="@+id/tvTargetHint" android:layout_width="wrap_content"
                        android:layout_height="wrap_content" android:text="Ej: Bogota Sur"
                        android:textSize="11sp" android:textColor="#546E7A" android:layout_marginBottom="8dp"/>
                    <com.google.android.material.textfield.TextInputLayout
                        android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:hint="Region o ID del usuario"
                        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                        app:boxBackgroundColor="#1E2A3A" app:boxStrokeColor="#2C3E50"
                        app:hintTextColor="#B0BEC5" android:layout_marginBottom="12dp">
                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/etTargetValue" android:layout_width="match_parent"
                            android:layout_height="wrap_content" android:textColor="#FFFFFF"/>
                    </com.google.android.material.textfield.TextInputLayout>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Combustible" android:textSize="12sp" android:textColor="#B0BEC5"
                        android:layout_marginBottom="6dp"/>
                    <androidx.cardview.widget.CardView android:layout_width="match_parent"
                        android:layout_height="wrap_content" android:layout_marginBottom="14dp"
                        app:cardBackgroundColor="#1E2A3A" app:cardCornerRadius="12dp" app:cardElevation="0dp">
                        <Spinner android:id="@+id/spinnerSubsidyFuel" android:layout_width="match_parent"
                            android:layout_height="48dp" android:paddingStart="12dp" android:popupBackground="#161B22"/>
                    </androidx.cardview.widget.CardView>
                    <com.google.android.material.textfield.TextInputLayout
                        android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:hint="Descuento (%)" style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                        app:boxBackgroundColor="#1E2A3A" app:boxStrokeColor="#2C3E50"
                        app:hintTextColor="#B0BEC5" android:layout_marginBottom="12dp">
                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/etDiscountPct" android:layout_width="match_parent"
                            android:layout_height="wrap_content" android:inputType="numberDecimal"
                            android:textColor="#FFFFFF"/>
                    </com.google.android.material.textfield.TextInputLayout>
                    <com.google.android.material.textfield.TextInputLayout
                        android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:hint="Fecha fin (ej: 31/12/2025)"
                        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                        app:boxBackgroundColor="#1E2A3A" app:boxStrokeColor="#2C3E50"
                        app:hintTextColor="#B0BEC5" android:layout_marginBottom="12dp">
                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/etEndDate" android:layout_width="match_parent"
                            android:layout_height="wrap_content" android:textColor="#FFFFFF"/>
                    </com.google.android.material.textfield.TextInputLayout>
                    <com.google.android.material.textfield.TextInputLayout
                        android:layout_width="match_parent" android:layout_height="wrap_content"
                        android:hint="Notas (opcional)"
                        style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
                        app:boxBackgroundColor="#1E2A3A" app:boxStrokeColor="#2C3E50"
                        app:hintTextColor="#B0BEC5" android:layout_marginBottom="16dp">
                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/etSubsidyNotes" android:layout_width="match_parent"
                            android:layout_height="wrap_content" android:textColor="#FFFFFF"/>
                    </com.google.android.material.textfield.TextInputLayout>
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnRegistrarSubsidy" android:layout_width="match_parent"
                        android:layout_height="52dp" android:text="Registrar subsidio"
                        android:textAllCaps="false" android:textSize="15sp"
                        app:cornerRadius="12dp" app:backgroundTint="#FF8F00"/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>
            <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
                android:text="Subsidios registrados" android:textSize="13sp"
                android:textColor="#B0BEC5" android:textAllCaps="true"
                android:layout_marginStart="20dp" android:layout_marginTop="8dp"
                android:layout_marginBottom="10dp"/>
            <androidx.recyclerview.widget.RecyclerView android:id="@+id/recyclerSubsidies"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:nestedScrollingEnabled="false"/>
        </LinearLayout>
    </ScrollView>
</LinearLayout>